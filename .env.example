# ---- Tenant Hawk environment ----
# Local dev uses Dockerized Postgres (docker compose up -d).
# Swap DATABASE_URL to the Supabase pooler when ready — no code changes.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/tenanthawk

# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Microsoft Graph — multi-tenant, read-only, app-only Entra app.
# Leave MS_CLIENT_ID blank to run in DEMO scan mode (no Azure needed).
MS_CLIENT_ID=
MS_CLIENT_SECRET=
MS_REDIRECT_URI=http://localhost:3000/api/connect/callback

# Stripe (test mode). STRIPE_PRICE_PRO is the monthly recurring Price ID for Pro.
# STRIPE_PRICE_PRO_ANNUAL is the yearly Price ID (e.g. $490/yr — 2 months free vs monthly).
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO=
STRIPE_PRICE_PRO_ANNUAL=
# Enterprise Starter ($299/mo or $2990/yr — 10 client tenants included).
STRIPE_PRICE_ENTERPRISE=
STRIPE_PRICE_ENTERPRISE_ANNUAL=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Email alerts (Purelymail SMTP). Without SMTP_* vars, alert emails log to the console in dev.
SMTP_HOST=smtp.purelymail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=alerts@yourdomain.com
SMTP_PASS=
EMAIL_FROM=Tenant Hawk <alerts@tenanthawk.io>
# Public app URL in emails (defaults to https://tenanthawk.io when NEXT_PUBLIC_APP_URL is localhost)
EMAIL_APP_URL=https://tenanthawk.io

# Marketing lifecycle webhook (e.g. n8n). When set, a "scan.completed" event is
# POSTed here after every completed scan. Unset = no-op. See marketing/automation/.
MARKETING_WEBHOOK_URL=
MARKETING_WEBHOOK_SECRET=

# n8n (local). MCP token: Settings → Instance-level MCP. API key: Settings → n8n API.
N8N_MCP_TOKEN=
N8N_API_KEY=

# Protect cron endpoints in production (Vercel sends Authorization: Bearer <secret>).
CRON_SECRET=

# OpenAI — Pro AI remediation (lazy-generated per finding, cached in DB).
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Comma-separated emails with manual Enterprise (MSP console) access before Stripe checkout.
# MSP_ENTITLEMENT_ALLOWLIST=partner@example.com,msp@tenanthawk.app

# Demo accounts that can switch Free / Pro / Enterprise on Billing without Stripe checkout.
# Defaults include demo@tenanthawk.app and msp@tenanthawk.app (plus SEED_EMAIL / SEED_MSP_EMAIL).
# DEMO_PLAN_SWITCH_EMAILS=demo@tenanthawk.app,msp@tenanthawk.app

# Client tenants included on Enterprise Starter (default 10).
# ENTERPRISE_CLIENT_CAP=10

# Enterprise workspace — branded subdomains and SSO
# ENTERPRISE_ROOT_DOMAIN=tenanthawk.io
# Local subdomain testing: ENTERPRISE_ROOT_DOMAIN=localhost (then use demo.localhost:3000, admin.localhost:3000)
# ENTERPRISE_COOKIE_DOMAIN=.tenanthawk.io
# ENTERPRISE_SSO_ENABLED=true
# ENTERPRISE_RESERVED_SLUGS=www,api,app,admin
# Platform operator console at admin.tenanthawk.io (reserved slug; not an MSP org)
# PLATFORM_ADMIN_SUBDOMAIN=admin
# Platform owner user id(s) for Better Auth admin plugin (comma-separated)
# TENANT_HAWK_ADMIN_USER_ID=
# Signup stores accountType on user: individual (default) or msp

# Public support contact (shown in footer; mailbox optional)
# SUPPORT_EMAIL=support@tenanthawk.io
