{
  "name": "Tenant Hawk - Post-Scan Lifecycle",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "tenanthawk-scan-completed",
        "responseMode": "onReceived",
        "options": {}
      },
      "id": "webhook-trigger",
      "name": "Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [-560, 320],
      "webhookId": "tenanthawk-scan-completed"
    },
    {
      "parameters": {
        "conditions": {
          "options": { "caseSensitive": true, "typeValidation": "loose" },
          "conditions": [
            {
              "id": "sig",
              "leftValue": "={{ $json.headers['x-th-signature'] }}",
              "rightValue": "REPLACE_WITH_SHARED_SECRET",
              "operator": { "type": "string", "operation": "equals" }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "verify-secret",
      "name": "Verify secret",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [-360, 320]
    },
    {
      "parameters": {},
      "id": "rejected",
      "name": "Rejected (bad secret)",
      "type": "n8n-nodes-base.noOp",
      "typeVersion": 1,
      "position": [-160, 560]
    },
    {
      "parameters": {
        "conditions": {
          "options": { "caseSensitive": true, "typeValidation": "loose" },
          "conditions": [
            {
              "id": "free",
              "leftValue": "={{ $json.body.plan }}",
              "rightValue": "free",
              "operator": { "type": "string", "operation": "equals" }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "is-free",
      "name": "Is free plan?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [-160, 320]
    },
    {
      "parameters": {},
      "id": "skip-paid",
      "name": "Skip (already paid)",
      "type": "n8n-nodes-base.noOp",
      "typeVersion": 1,
      "position": [40, 560]
    },
    {
      "parameters": {
        "conditions": {
          "options": { "caseSensitive": true, "typeValidation": "loose" },
          "conditions": [
            {
              "id": "msp",
              "leftValue": "={{ $json.body.isLikelyMsp }}",
              "rightValue": true,
              "operator": { "type": "boolean", "operation": "true", "singleValue": true }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "is-msp",
      "name": "Is likely MSP?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [40, 320]
    },

    {
      "parameters": {
        "fromEmail": "Tenant Hawk <hello@tenanthawk.io>",
        "toEmail": "={{ $('Webhook').item.json.body.user.email }}",
        "subject": "=Your tenant scored {{ $('Webhook').item.json.body.scan.score }}/100",
        "emailFormat": "text",
        "text": "=Hi {{ ($('Webhook').item.json.body.user.name || '').split(' ')[0] || 'there' }},\n\nYour scan is done. Tenant Hawk gave {{ $('Webhook').item.json.body.tenant.name }} a health score of {{ $('Webhook').item.json.body.scan.score }}/100, with {{ $('Webhook').item.json.body.scan.severityHighCount }} high-severity issues.\n\nThe biggest one right now: {{ $('Webhook').item.json.body.scan.topFinding }}.\n\nUnlock the full report to see every finding, the severity, the dollar impact and step-by-step remediation:\nhttps://tenanthawk.io/dashboard/report\n\nFounding users lock 25% off for life with code EARLYBIRD26.\n\n- Tenant Hawk",
        "options": {}
      },
      "id": "send-a1",
      "name": "A1 - Your score",
      "type": "n8n-nodes-base.emailSend",
      "typeVersion": 2.1,
      "position": [260, 200],
      "credentials": { "smtp": { "id": "REPLACE_SMTP_CRED_ID", "name": "Tenant Hawk Marketing SMTP" } }
    },
    {
      "parameters": { "amount": 1, "unit": "days" },
      "id": "wait-a1",
      "name": "Wait 1 day",
      "type": "n8n-nodes-base.wait",
      "typeVersion": 1.1,
      "position": [460, 200],
      "webhookId": "wait-a1"
    },
    {
      "parameters": {
        "fromEmail": "Tenant Hawk <hello@tenanthawk.io>",
